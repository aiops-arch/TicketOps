{
  "mcpServers": {
    "openclaw": {
      "command": "openclaw.cmd",
      "args": [
        "mcp",
        "serve",
        "--url",
        "wss://your-openclaw-gateway:18789",
        "--token-file",
        ".secrets/openclaw-gateway.token"
      ]
    },
    "ticketops-flow": {
      "command": "node",
      "args": [
        "mcp/openclaw-ticketops-mcp.js"
      ],
      "env": {
        "TICKETOPS_MODE": "operations-coordinator"
      }
    }
  }
}
